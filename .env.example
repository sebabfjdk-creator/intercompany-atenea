# Copiar a .env y ajustar. NUNCA versionar el .env real.
ENVIRONMENT=development
DEBUG=true

# Base de datos (docker-compose usa el servicio 'db')
DATABASE_URL=postgresql+psycopg://atenea:atenea@db:5432/atenea

# Seguridad — generar uno propio: python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=cambia-esto-por-un-secreto-largo
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# Conciliación (parametrizable)
TOLERANCIA_ABS_COP=1000
TOLERANCIA_PCT=0.005

# Seed de usuarios iniciales (solo dev)
SEED_ADMIN_EMAIL=admin@atenea.com
SEED_ADMIN_PASSWORD=atenea-admin
SEED_ADMINCO_EMAIL=colombia@atenea.com
SEED_ADMINCO_PASSWORD=atenea-co
